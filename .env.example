# =========================================================
# ARÉTÉ — Environment Variables
# Copy this file to .env.local and fill in your own values.
# Get these from your Supabase project dashboard:
# Project Settings → API
# =========================================================

# Public Supabase URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser (RLS protects writes)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SECRET. Server-side only. Never expose to the
# browser or commit to version control. Used for admin-only
# operations that must bypass Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL, used for sitemap.xml and robots.txt generation.
# Use http://localhost:3000 during local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
